{
  "manifest_version": 3,
  "name": "Petmon",
  "version": "3.0",
  "description": "A small animated pet (cat, duck, or your own custom pet) walks along the bottom of every page and makes a sound when you click.",
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "permissions": ["storage", "offscreen"],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_title": "Petmon settings"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/pet.js"],
      "css": ["src/content/pet.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/sounds/*.mp3",
        "assets/sounds/*.wav",
        "assets/sprites/*.png"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
